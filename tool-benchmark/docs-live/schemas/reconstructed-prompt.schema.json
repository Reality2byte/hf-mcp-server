{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "prompt", "confidence", "label_note"],
  "properties": {
    "id": {
      "type": "string"
    },
    "prompt": {
      "type": "string",
      "minLength": 20
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "label_note": {
      "type": "string",
      "minLength": 10
    }
  }
}
